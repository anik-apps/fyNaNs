# ===========================================
# fyNaNs Production Environment Configuration
# ===========================================
# Copy to .env.production and fill in all values
# NEVER commit .env.production to git

# Domain
DOMAIN=fynans.yourdomain.com
ACME_EMAIL=you@yourdomain.com

# Database
POSTGRES_USER=fynans
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=fynans

# JWT (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
ENCRYPTION_MASTER_SECRET=CHANGE_ME_GENERATE_WITH_SECRETS

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Resend (email)
RESEND_API_KEY=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENVIRONMENT=sandbox

# OCI Object Storage (for backups)
OCI_BUCKET_NAME=fynans-backups
OCI_NAMESPACE=your_namespace
OCI_REGION=us-ashburn-1
