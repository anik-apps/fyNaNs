# Database
DATABASE_URL=postgresql+asyncpg://fynans:fynans_dev@localhost:5432/fynans

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption (for Plaid tokens)
ENCRYPTION_MASTER_SECRET=change-me-in-production

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Resend (email)
RESEND_API_KEY=

# Plaid (get sandbox keys at https://dashboard.plaid.com/developers/keys)
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=http://localhost:8888/api/plaid/webhook

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
